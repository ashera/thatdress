# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/frockd

# Set to "true" to enable SSL (e.g., when using a managed Postgres host)
# DATABASE_SSL=true

# Resend (transactional email). If unset, email sends become no-ops and
# password reset / message notifications silently skip.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=frockd <noreply@frockd.com.au>

# Public base URL for absolute links inside transactional emails (verify,
# password reset, message notifications, saved-search digest).
# Set this in any environment that sends real emails — including local
# dev if you want emails to point at the deployed site rather than
# http://localhost:3000 (which the recipient can't reach from their inbox).
# Falls back to the request's host header when unset.
# APP_URL=https://www.frockd.com.au

# Pinterest API v5 Bearer access token. Required for the
# /admin/links/pinterest pin composer (lists boards + creates pins).
# Use a trial access token from the Pinterest developer portal
# (30-day expiry) or a long-lived OAuth user token. Scopes needed:
#   boards:read, pins:write
# Without this, the pin composer renders a 'not configured' notice
# and the submit button stays disabled.
# PINTEREST_KEY=pina_...
